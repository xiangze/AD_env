# ============================================================
# .env.example
# 環境変数テンプレート。.env にコピーして編集してください。
# cp .env.example .env
# ============================================================

# ホストのデータルート (nuScenes / nuPlan 生データ)
HOST_DATA_ROOT=/mnt/data

# ホストのチェックポイントディレクトリ
HOST_CKPT_DIR=/mnt/ckpts

# GPU 割り当て
UNIAD_GPUS=0,1,2,3,4,5,6,7
ALGE_GPUS=0,1,2,3,4,5,6,7
SIME_GPUS=4,5,6,7

# 分散学習
MASTER_ADDR=localhost
MASTER_PORT=29500

# W&B (任意)
WANDB_API_KEY=
WANDB_PROJECT=uniad-worldengine
